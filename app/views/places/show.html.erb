<a href="/places">Back to all places</a>

<h1><%= @place.name %></h1>

<h2>Entries</h2>

<ul>
  <% @entries.each do |entry| %>
    <li>
      <strong><%= entry.title %></strong> (<%= entry.occurred_on %>)<br>
      <%= entry.description %>
    </li>
  <% end %>
</ul>

<a href="/entries/new?place_id=<%= @place.id %>">Log a new entry</a>
